{% if site.contacts %}
<div class="home-item">
  <h1 class="home-item__header"><code>rocx</code> Around the Web</h1>
  <dl>
    {%- for contact in site.contacts %}
    <dt>{{ contact.name }}</dt>
    <dd>
      {%- if contact.title %}
      <a rel="me" href="{{ contact.uri }}">{{ contact.title }}</a>
      {% else %}
      <a rel="me" href="{{ contact.uri }}">{{ contact.uri }}</a>
      {%- endif %}
    </dd>
    {%- endfor %}
  </dl>
</div>
{% endif %}

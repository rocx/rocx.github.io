<meta property="og:title"
      content="{{ page.title }}">
<meta property="og:type"
      content="article">
<meta property="og:image"
      content="https://avatars0.githubusercontent.com/u/3887832">
<meta property="og:url"
      content="{{ page.url }}">
{% if layout.is_post? %}
<meta property="og:article:published_tile"
      content="{{ page.date }}">
<meta property="og:article:author"
      content="Box O'Rocks">
{% endif %}
{% comment %}
Local Variables:
mode: mhtml
End:
{% endcomment %}
